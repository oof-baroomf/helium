+
+void BrowserViewTabbedLayoutImpl::DoZenModeVisualAdjustments() {
+  auto* background = static_cast<CustomCornersBackground*>(
+      views().top_container->background());
+  const int radius =
+      background
+          ? background->GetWindowCorner(/*upper=*/true).radius.value_or(0)
+          : 0;
+
+  // Applies a rounded clip to a view's upper corners.  Clears the clip if
+  // |radius| is zero.  |round_leading| and |round_trailing| select which
+  // corners to round.
+  auto clip_upper_corners = [radius](views::View* view, bool round_leading,
+                                     bool round_trailing) {
+    if (!view) {
+      return;
+    }
+    if (view->width() <= 0 || view->height() <= 0) {
+      if (!view->clip_path().isEmpty()) {
+        view->SetClipPath(SkPath());
+      }
+      return;
+    }
+    if (radius > 0 && (round_leading || round_trailing)) {
+      const SkScalar r = SkIntToScalar(radius);
+      const SkVector radii[4] = {
+          round_leading ? SkVector{r, r} : SkVector{0, 0},
+          round_trailing ? SkVector{r, r} : SkVector{0, 0},
+          {0, 0},
+          {0, 0}};
+      view->SetClipPath(SkPath::RRect(SkRRect::MakeRectRadii(
+          SkRect::MakeWH(view->width(), view->height()), radii)));
+    } else if (!view->clip_path().isEmpty()) {
+      view->SetClipPath(SkPath());
+    }
+  };
+
+  // Clip the top container to its rounded background so child views
+  // (toolbar, bookmarks bar) don't paint over the rounded corners.
+  views::View* top_container = views().top_container;
+  if (top_container->bounds().y() == 0) {
+    clip_upper_corners(top_container, true, true);
+  }
+}
