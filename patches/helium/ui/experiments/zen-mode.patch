+void BrowserViewTabbedLayoutImpl::AdjustTopContainerForZenMode(
+    ProposedLayout& top_container_layout,
+    BrowserLayoutParams& params,
+    float top_chrome_ratio) const {
+#if BUILDFLAG(IS_LINUX)
+  // When chrome is hidden on a frame without a native top border (classic
+  // theme on Linux), reserve a thin strip so the top container background
+  // can paint the window's top border.  Not needed on Mac (AppKit titlebar)
+  // or GTK/Qt (native frame border).
+  constexpr int kZenModeTopBorderHeight = 4;
+  if (top_chrome_ratio >= 1.0f || views().browser_view->bounds().y() > 0) {
+    return;
