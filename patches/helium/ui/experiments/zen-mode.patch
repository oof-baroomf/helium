+
+void BrowserView::AnimationProgressed(const gfx::Animation* animation) {
+  if (animation == &zen_top_chrome_animation_ ||
+      animation == &zen_side_chrome_animation_) {
+    if (animation == &zen_top_chrome_animation_ &&
+        vertical_tab_strip_region_view_) {
+      vertical_tab_strip_region_view_->UpdateInteriorMargin();
+    }
+    InvalidateLayout();
+    if (auto* frame_view = GetFrameView()) {
+      frame_view->InvalidateLayout();
+      // Fade caption buttons with the toolbar.  The toolbar still reserves
+      // their space via exclusion areas since the buttons remain visible to
+      // the layout system (only their rendering opacity is changed).
+      frame_view->SetCaptionButtonsOpacity(GetTopChromeRevealRatio());
+    }
+  }
+}
+
+void BrowserView::AnimationEnded(const gfx::Animation* animation) {
+  AnimationProgressed(animation);
+  // Update content corner fills now that the animation has settled.
+  if (multi_contents_view_) {
+    multi_contents_view_->MaybeUpdateContentsBorderAndOverlay();
+  }
 }
 
