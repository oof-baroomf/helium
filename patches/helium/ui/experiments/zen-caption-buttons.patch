+void OpaqueBrowserFrameView::SetCaptionButtonsOpacity(float opacity) {
+  auto apply = [opacity](views::Button* view) {
+    if (!view) {
+      return;
+    }
+    view->SetCanProcessEventsWithinSubtree(opacity > 0.0f);
+    if (opacity < 1.0f) {
+      if (!view->layer()) {
+        view->SetPaintToLayer();
+        view->layer()->SetFillsBoundsOpaquely(false);
+      }
+      view->layer()->SetOpacity(opacity);
+    } else if (view->layer()) {
+      view->DestroyLayer();
+    }
+  };
+  apply(minimize_button_);
+  apply(maximize_button_);
+  apply(restore_button_);
+  apply(close_button_);
+}
