+bool ShouldShowTrailingSeparatorAfterLastTab(
+    BrowserWindowInterface* browser_window_interface) {
+  // Match HorizontalTabStripRegionView::ShouldShowNewTabButton().
+  if (!browser_window_interface) {
+    return true;
+  }
+
+  auto* const app_controller =
+      web_app::AppBrowserController::From(browser_window_interface);
+  if (app_controller && app_controller->ShouldHideNewTabButton()) {
+    return false;
+  }
+
+  auto* const layout_controller =
+      HeliumLayoutStateController::From(browser_window_interface);
+
+  if (!layout_controller) {
+    return true;
+  }
+
+  return layout_controller->IsClassicLayout() ||
