+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_HELIUM_HELIUM_LAYOUT_STATE_CONTROLLER_H_
+#define CHROME_BROWSER_UI_HELIUM_HELIUM_LAYOUT_STATE_CONTROLLER_H_
+
+#include "base/callback_list.h"
+#include "base/memory/raw_ptr.h"
+#include "components/prefs/pref_change_registrar.h"
+#include "ui/base/unowned_user_data/scoped_unowned_user_data.h"
+
+class BrowserWindowInterface;
+class PrefService;
+
+enum class HeliumLayoutType {
+  kClassic = 0,
+  kCompact = 1,
+  kVertical = 2,
+  kDynamic = 3,
+  kMaxValue = kDynamic,
+};
+
+class HeliumLayoutStateController {
+ public:
+  DECLARE_USER_DATA(HeliumLayoutStateController);
+
+  explicit HeliumLayoutStateController(BrowserWindowInterface* browser_window,
+                                       PrefService* pref_service);
+  HeliumLayoutStateController(const HeliumLayoutStateController&) = delete;
+  HeliumLayoutStateController& operator=(const HeliumLayoutStateController&) =
+      delete;
+  ~HeliumLayoutStateController();
+
+  static HeliumLayoutStateController* From(
+      BrowserWindowInterface* browser_window);
+
+  bool IsClassicLayout() const;
+  bool IsCompactLayout() const;
+  bool IsVerticalLayout() const;
+  bool IsDynamicLayout() const;
+
+  void SetBrowserLayout(HeliumLayoutType layout);
+  HeliumLayoutType GetBrowserLayout() const;
+
+  using StateChangedCallback =
+      base::RepeatingCallback<void(HeliumLayoutStateController*)>;
+  base::CallbackListSubscription RegisterOnStateChanged(
+      StateChangedCallback callback);
+
+ private:
+  void NotifyStateChanged();
+
+  const raw_ptr<PrefService> pref_service_;
+  PrefChangeRegistrar pref_change_registrar_;
+  base::RepeatingCallbackList<void(HeliumLayoutStateController*)>
+      on_state_changed_callback_list_;
+  ui::ScopedUnownedUserData<HeliumLayoutStateController>
+      scoped_unowned_user_data_;
+};
+
+#endif  // CHROME_BROWSER_UI_HELIUM_HELIUM_LAYOUT_STATE_CONTROLLER_H_
--- /dev/null
+++ b/chrome/browser/ui/helium/helium_layout_state_controller.cc
@@ -0,0 +1,80 @@
+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/helium/helium_layout_state_controller.h"
+
+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/tabs/features.h"
+#include "chrome/common/pref_names.h"
+#include "components/prefs/pref_service.h"
+
+DEFINE_USER_DATA(HeliumLayoutStateController);
+
+HeliumLayoutStateController::HeliumLayoutStateController(
+    BrowserWindowInterface* browser_window,
+    PrefService* pref_service)
+    : pref_service_(pref_service),
+      scoped_unowned_user_data_(browser_window->GetUnownedUserDataHost(),
+                                *this) {
+  pref_change_registrar_.Init(pref_service_);
+
+  pref_change_registrar_.Add(
+      prefs::kHeliumLayout,
+      base::BindRepeating(&HeliumLayoutStateController::NotifyStateChanged,
+                          base::Unretained(this)));
+}
+
+HeliumLayoutStateController::~HeliumLayoutStateController() = default;
+
+// static
+HeliumLayoutStateController* HeliumLayoutStateController::From(
+    BrowserWindowInterface* browser_window) {
+  return Get(browser_window->GetUnownedUserDataHost());
+}
+
+bool HeliumLayoutStateController::IsClassicLayout() const {
+  return GetBrowserLayout() == HeliumLayoutType::kClassic;
+}
+
+bool HeliumLayoutStateController::IsCompactLayout() const {
+  return GetBrowserLayout() == HeliumLayoutType::kCompact;
+}
+
+bool HeliumLayoutStateController::IsVerticalLayout() const {
+  return GetBrowserLayout() == HeliumLayoutType::kVertical;
+}
+
+bool HeliumLayoutStateController::IsDynamicLayout() const {
+  return GetBrowserLayout() == HeliumLayoutType::kDynamic;
+}
+
+void HeliumLayoutStateController::SetBrowserLayout(HeliumLayoutType layout) {
+  pref_service_->SetInteger(prefs::kHeliumLayout, std::to_underlying(layout));
+}
+
+HeliumLayoutType HeliumLayoutStateController::GetBrowserLayout() const {
+  int layout_value = pref_service_->GetInteger(prefs::kHeliumLayout);
+
+  if (!tabs::IsVerticalTabsFeatureEnabled() &&
+      layout_value == std::to_underlying(HeliumLayoutType::kVertical)) {
+    return HeliumLayoutType::kClassic;
+  }
+
+  if (layout_value < std::to_underlying(HeliumLayoutType::kClassic) ||
+      layout_value > std::to_underlying(HeliumLayoutType::kMaxValue)) {
+    return HeliumLayoutType::kClassic;
+  }
+
+  return static_cast<HeliumLayoutType>(layout_value);
+}
+
+base::CallbackListSubscription
+HeliumLayoutStateController::RegisterOnStateChanged(
+    StateChangedCallback callback) {
+  return on_state_changed_callback_list_.Add(std::move(callback));
+}
+
+void HeliumLayoutStateController::NotifyStateChanged() {
+  on_state_changed_callback_list_.Notify(this);
+}
